# Copy to .env before running docker compose. These are local demo values only.

# MySQL
MYSQL_DATABASE=fleet
MYSQL_USER=fleet
MYSQL_PASSWORD=fleet
MYSQL_ROOT_PASSWORD=fleet-root

# RabbitMQ
RABBITMQ_USER=fleet
RABBITMQ_PASSWORD=fleet

# Device simulator
SIM_DEVICE_COUNT=12
SIM_PUBLISH_INTERVAL=2s
SIM_ANOMALY_RATE=0.05
SIM_CORRUPT_RATE=0.01
